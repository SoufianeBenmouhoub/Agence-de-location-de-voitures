@model IEnumerable<Locatic.Models.Modele>

<h1>Liste des modèles</h1>

<a href="/Modeles/Create">
    Ajouter un modèle
</a>

<table border="1">
    <tr>
        <th>Id</th>
        <th>Nom</th>
        <th>MarqueId</th>
    </tr>

    @foreach(var item in Model)
    {
        <tr>
            <td>@item.Id</td>
            <td>@item.Nom</td>
            <td>@item.MarqueId</td>
        </tr>
    }
</table>